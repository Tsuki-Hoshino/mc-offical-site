<VirtualHost *:80>
    ServerName mc.example.com
    Redirect permanent / https://mc.example.com/
</VirtualHost>

<VirtualHost *:443>
    ServerName mc.example.com
    DocumentRoot /var/www/mc-official-site/website

    SSLEngine on
    SSLCertificateFile /etc/letsencrypt/live/mc.example.com/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/mc.example.com/privkey.pem

    LimitRequestBody 33554432
    Header always set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    <Directory /var/www/mc-official-site/website>
        Options -Indexes
        AllowOverride None
        Require all granted
        DirectoryIndex index.html index.php
    </Directory>

    <DirectoryMatch "^/var/www/mc-official-site/website/(?:config|data|api/(?:lib|cron))(?:/|$)">
        Require all denied
    </DirectoryMatch>

    <FilesMatch "\.php$">
        SetHandler "proxy:unix:/run/php/php8.3-fpm.sock|fcgi://localhost/"
    </FilesMatch>

    ErrorLog ${APACHE_LOG_DIR}/mc-official-site-error.log
    CustomLog ${APACHE_LOG_DIR}/mc-official-site-access.log combined
</VirtualHost>
